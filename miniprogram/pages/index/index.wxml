<view class="container">
  <!-- Tab 栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="onTabChange"
      data-key="{{item.key}}"
    >
      <text class="tab-label">{{item.label}}</text>
      <view class="tab-indicator" wx:if="{{currentTab === item.key}}"></view>
    </view>
  </view>

  <!-- 活动列表 -->
  <view class="tab-content" wx:if="{{currentTab === '' || currentTab === 'activity'}}">
    <view class="search-box">
      <input class="search-input" placeholder="搜索活动" bindinput="onSearch" />
    </view>

    <view class="activity-list">
      <view class="activity-card" wx:for="{{activities}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <image class="activity-cover" src="{{item.cover}}" mode="aspectFill" />
        <view class="activity-info">
          <text class="activity-title">{{item.title}}</text>
          <text class="activity-date">{{item.date}}</text>
          <view class="activity-meta">
            <text class="activity-location">📍 {{item.location}}</text>
            <text class="activity-participants">{{item.signupCount}}/{{item.maxParticipants}} 人已报名</text>
          </view>
          <view class="recent-signups" wx:if="{{item.recentSignups && item.recentSignups.length > 0}}">
            <image
              wx:for="{{item.recentSignups}}"
              wx:key="userId"
              class="signup-avatar"
              src="{{item.avatar}}"
              mode="aspectFill"
            />
            <view class="more-signups" wx:if="{{item.signupCount > 4}}">
              <text>+{{item.signupCount - 4}}</text>
            </view>
          </view>
          <view class="signup-deadline" wx:if="{{item.signupEndTime}}">
            <text>⏰ 报名截止：{{item.signupEndTime}}</text>
          </view>
          <view class="activity-footer">
            <text class="activity-price">¥{{item.price}}</text>
            <button class="btn-signup" wx:if="{{item.status === 0}}">立即报名</button>
            <text class="activity-status" wx:elif="{{item.status === 1}}">报名已满</text>
            <text class="activity-status" wx:else>已结束</text>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{activities.length === 0 && !loading}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无活动</text>
      </view>
    </view>
  </view>

  <!-- 挑战列表 -->
  <view class="tab-content" wx:if="{{currentTab === 'challenge'}}">
    <view class="challenge-list">
      <view class="challenge-card" wx:for="{{challenges}}" wx:key="id">
        <view class="challenge-icon">{{item.icon}}</view>
        <view class="challenge-info">
          <text class="challenge-title">{{item.title}}</text>
          <text class="challenge-desc">{{item.description}}</text>
          <view class="progress-bar">
            <view class="progress" style="width: {{item.progress}}%"></view>
          </view>
          <text class="progress-text">{{item.current}}/{{item.target}} {{item.unit}}</text>
        </view>
        <view class="challenge-badge {{item.completed ? 'completed' : ''}}">
          <text>{{item.badge}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 赛事列表 -->
  <view class="tab-content" wx:if="{{currentTab === 'race'}}">
    <view class="empty-state">
      <text class="empty-icon">🏆</text>
      <text class="empty-text">赛事功能即将上线</text>
      <text class="empty-hint">敬请期待</text>
    </view>
  </view>

  <!-- 俱乐部列表 -->
  <view class="tab-content" wx:if="{{currentTab === 'club'}}">
    <view class="empty-state">
      <text class="empty-icon">🚴</text>
      <text class="empty-text">俱乐部功能即将上线</text>
      <text class="empty-hint">敬请期待</text>
    </view>
  </view>
</view>
