page {
  background-color: #f5f5f5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  position: relative;
}

.tab-label {
  font-size: 28rpx;
  color: #999;
  transition: color 0.2s;
}

.tab-item.active .tab-label {
  color: #ff6b35;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

/* Tab 内容区 */
.tab-content {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 搜索框 */
.search-box {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  font-size: 28rpx;
}

/* 活动卡片 */
.activity-card {
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.activity-cover {
  width: 100%;
  height: 320rpx;
  background: #eee;
}

.activity-info {
  padding: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.activity-date {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 15rpx;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.activity-location,
.activity-participants {
  font-size: 26rpx;
  color: #666;
}

.activity-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.activity-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.btn-signup {
  background: #07c160;
  color: white;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 6rpx;
}

.activity-status {
  font-size: 26rpx;
  color: #999;
}

/* 最近报名头像 */
.recent-signups {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.signup-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.more-signups {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
}

/* 报名截止 */
.signup-deadline {
  background: #fff3e0;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 15rpx;
}

.signup-deadline text {
  font-size: 24rpx;
  color: #ff9800;
}

/* 挑战卡片 */
.challenge-list {
  padding: 0;
}

.challenge-card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.challenge-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.challenge-info {
  flex: 1;
}

.challenge-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.challenge-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.progress {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #34d399);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
}

.challenge-badge {
  font-size: 48rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}
