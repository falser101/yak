page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.search-box {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  font-size: 28rpx;
}

.activity-card {
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.activity-cover {
  width: 100%;
  height: 320rpx;
  background: #eee;
}

.activity-info {
  padding: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.activity-date {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 15rpx;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.activity-location,
.activity-participants {
  font-size: 26rpx;
  color: #666;
}

.activity-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.activity-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.btn-signup {
  background: #07c160;
  color: white;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 6rpx;
}

.activity-status {
  font-size: 26rpx;
  color: #999;
}

/* 最近报名用户头像 */
.recent-signups {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.signup-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.signup-avatar[imageerror] {
  background: #e0e0e0;
}

.more-signups {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
}

/* 报名截止时间提示 */
.signup-deadline {
  background: #fff3e0;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 15rpx;
}

.signup-deadline text {
  font-size: 24rpx;
  color: #ff9800;
}
