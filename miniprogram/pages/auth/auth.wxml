<view class="container">
  <view class="header">
    <text class="title">实名认证</text>
    <text class="subtitle">请填写您的真实信息，用于活动报名</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="label">姓名 *</text>
      <input class="input" placeholder="请输入真实姓名" value="{{realName}}" data-field="realName" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">证件号 *</text>
      <input class="input" placeholder="请输入身份证号" value="{{idCard}}" data-field="idCard" bindinput="onInput" maxlength="18" />
    </view>

    <view class="form-item">
      <text class="label">性别 *</text>
      <radio-group class="gender-group" data-field="gender" bindchange="onGenderChange">
        <label class="gender-option {{gender === 1 ? 'selected' : ''}}">
          <radio value="1" checked="{{gender === 1}}" /> 男
        </label>
        <label class="gender-option {{gender === 2 ? 'selected' : ''}}">
          <radio value="2" checked="{{gender === 2}}" /> 女
        </label>
      </radio-group>
    </view>

    <view class="divider"></view>

    <view class="form-item">
      <text class="label">本人电话 *</text>
      <view class="phone-row">
        <input class="input phone-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{userPhone}}" data-field="userPhone" bindinput="onInput" />
        <button class="btn-wechat" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber" disabled="{{phoneLoading}}">
          {{phoneLoading ? '获取中...' : '微信授权'}}
        </button>
      </view>
    </view>

    <view class="divider"></view>

    <view class="section-title">紧急联系人</view>

    <view class="form-item">
      <text class="label">联系人姓名 *</text>
      <input class="input" placeholder="请输入紧急联系人姓名" value="{{emergencyName}}" data-field="emergencyName" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">联系人电话 *</text>
      <input class="input" type="number" placeholder="请输入紧急联系人电话" value="{{emergencyPhone}}" data-field="emergencyPhone" bindinput="onInput" maxlength="11" />
    </view>
  </view>

  <view class="tip-card">
    <text class="tip-title">温馨提示</text>
    <text class="tip-text">• 实名认证信息仅用于活动报名</text>
    <text class="tip-text">• 您的信息将被严格保密</text>
    <text class="tip-text">• 请填写真实有效的联系信息</text>
  </view>

  <view class="btn-container">
    <button class="btn-submit" bindtap="submitAuth" disabled="{{!canSubmit}}">提交认证</button>
  </view>
</view>
