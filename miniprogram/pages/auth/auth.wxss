page {
  background-color: #f5f5f5;
}

.container {
  padding: 30rpx;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.form-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.input {
  width: 100%;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.gender-group {
  display: flex;
  gap: 40rpx;
}

.gender-option {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  padding: 15rpx 30rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}

.gender-option.selected {
  background: #e8f5e9;
  color: #07c160;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}

.section-title {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.tip-card {
  background: #fff3e0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.tip-title {
  font-size: 28rpx;
  color: #ff9800;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.tip-text:last-child {
  margin-bottom: 0;
}

.btn-container {
  padding: 0 20rpx;
}

.btn-submit {
  width: 100%;
  background: #07c160;
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-submit[disabled] {
  background: #ccc;
}

.phone-row {
  display: flex;
  gap: 16rpx;
}

.phone-input {
  flex: 1;
}

.btn-wechat {
  padding: 16rpx 24rpx;
  background: #07c160;
  color: white;
  border-radius: 8rpx;
  font-size: 26rpx;
  white-space: nowrap;
  line-height: 1.8;
}

.btn-wechat[disabled] {
  background: #a5d6a7;
}
