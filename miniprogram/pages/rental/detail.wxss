page {
  background: #f5f5f5;
}

.page-content {
  padding-bottom: 120rpx;
}

/* 封面 */
.rental-detail-cover {
  height: 480rpx;
  background: linear-gradient(135deg, #1a5f9e, #2d8bc9);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-emoji {
  font-size: 200rpx;
}

.back-btn {
  position: absolute;
  top: env(safe-area-inset-top, 20rpx);
  left: 20rpx;
  z-index: 10;
  width: 64rpx;
  height: 64rpx;
  background: rgba(0,0,0,0.3);
  border-radius: 50%;
  color: #fff;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-tag {
  position: absolute;
  top: calc(env(safe-area-inset-top, 20rpx) + 20rpx);
  right: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
}

.cover-tag.tag-hot { background: #ff4d4f; }
.cover-tag.tag-rec { background: #f5a623; }

/* 详情卡片 */
.rental-detail-card {
  background: #fff;
  margin: -60rpx 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.bike-detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.bike-detail-sub {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.bike-detail-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.price-label {
  font-size: 24rpx;
  color: #999;
}

.price-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #f5a623;
}

.price-unit {
  font-size: 24rpx;
  font-weight: normal;
  color: #999;
}

/* 套餐选择 */
.package-section {
  margin-top: 32rpx;
}

.package-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.package-scroll {
  white-space: nowrap;
}

.package-list {
  display: inline-flex;
  gap: 16rpx;
}

.package-item {
  display: inline-block;
  min-width: 160rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid #e8e8e8;
}

.package-item.active {
  background: #e6f2ff;
  border-color: #1a5f9e;
}

.pkg-name {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.package-item.active .pkg-name {
  color: #1a5f9e;
}

.pkg-price {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: 700;
}

.pkg-unit {
  font-size: 20rpx;
  font-weight: normal;
  color: #999;
}

/* 数量选择 */
.qty-section {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qty-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.qty-num {
  min-width: 72rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

/* 日期选择 */
.date-section {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.date-picker {
  background: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

/* 规格参数 */
.spec-section {
  margin-top: 32rpx;
}

.spec-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.spec-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.spec-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.spec-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 租赁须知 */
.notes-section {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #fff9e6;
  border-radius: 16rpx;
  border: 1rpx solid #ffe58f;
}

.notes-title {
  font-size: 24rpx;
  color: #ad6800;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.notes-text {
  font-size: 22rpx;
  color: #ad6800;
  line-height: 1.8;
  white-space: pre-line;
}

/* 底部下单栏 */
.order-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.order-total {
  flex: 1;
}

.total-label {
  font-size: 22rpx;
  color: #999;
}

.total-price {
  font-size: 36rpx;
  color: #ff6b00;
  font-weight: 700;
}

.order-btn {
  width: 200rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #1a5f9e, #2d8bc9);
  color: #fff;
  border: none;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 200rpx;
  margin-bottom: 60rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
