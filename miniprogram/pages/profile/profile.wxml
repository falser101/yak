<view class="container">
  <!-- 头部信息 -->
  <view class="profile-header">
    <view class="profile-info">
      <view class="profile-avatar">{{isLoggedIn ? '👤' : '👤'}}</view>
      <view class="profile-user">
        <view class="profile-name">{{isLoggedIn ? (userInfo.nickname || '微信用户') : '未登录'}}</view>
        <view class="profile-phone" wx:if="{{isLoggedIn && userInfo.phone}}">{{userInfo.phone}}</view>
        <view class="profile-phone" wx:if="{{isLoggedIn && !userInfo.phone}}">点击查看更多信息</view>
      </view>
    </view>
    <button wx:if="{{!isLoggedIn}}" class="login-btn" bindtap="doLogin">微信登录</button>
    <button wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="logout">退出</button>
  </view>

  <!-- 功能菜单 -->
  <view class="profile-menus">
    <view class="menu-item" bindtap="goPage" data-page="my-activity">
      <view class="menu-icon">📋</view>
      <view class="menu-label">我的报名</view>
      <view class="menu-count" wx:if="{{signupCount > 0}}">{{signupCount}}个活动</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-page="my-orders">
      <view class="menu-icon">🚴</view>
      <view class="menu-label">我的订单</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-page="profile-edit">
      <view class="menu-icon">⚙️</view>
      <view class="menu-label">个人信息</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-page="contact">
      <view class="menu-icon">📞</view>
      <view class="menu-label">联系客服</view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 其他 -->
  <view class="profile-menus">
    <view class="menu-item" bindtap="goPage" data-page="agreement">
      <view class="menu-icon">📜</view>
      <view class="menu-label">报名协议</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-page="about">
      <view class="menu-icon">ℹ️</view>
      <view class="menu-label">关于我们</view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
