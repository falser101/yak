page {
  background-color: #f0f4f8;
}

.container {
  padding-bottom: 120rpx;
}

/* 头部信息 */
.profile-header {
  background: linear-gradient(135deg, #1a5f9e 0%, #2d8bc9 100%);
  padding: 60rpx 32rpx 40rpx;
  color: white;
}

.profile-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  border: 4rpx solid white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.profile-user {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.profile-phone {
  font-size: 26rpx;
  opacity: 0.8;
}

.login-btn,
.logout-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  background: white;
  color: #1a5f9e;
  border: none;
  margin: 0;
}

.logout-btn {
  background: rgba(255,255,255,0.2);
  color: white;
}

/* 功能菜单 */
.profile-menus {
  background: white;
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  background: #f0f4f8;
  border-radius: 16rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
}

.menu-count {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.menu-arrow {
  color: #ccc;
  font-size: 28rpx;
}
