page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.user-header {
  background: linear-gradient(135deg, #07c160, #10b981);
  padding: 40rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: white;
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
}

.slogan {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 10rpx;
}

.login-btn,
.logout-btn {
  padding: 15rpx 40rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
}

.login-btn {
  background: white;
  color: #07c160;
}

.logout-btn {
  background: rgba(255,255,255,0.2);
  color: white;
}

.stats-row {
  display: flex;
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid #eee;
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #07c160;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.menu-section {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.menu-list {
  border-top: 1rpx solid #f5f5f5;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}
