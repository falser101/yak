page {
  background-color: #f0f4f8;
}

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.order-list {
  padding: 0;
}

.order-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.order-card-header {
  padding: 24rpx 28rpx;
  background: #fafafa;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-paid {
  background: #e6f7ff;
  color: #1890ff;
}

.status-done {
  background: #f6ffed;
  color: #52c41a;
}

.status-cancel {
  background: #f5f5f5;
  color: #999;
}

.order-card-body {
  padding: 28rpx;
}

.order-info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.order-info-label {
  color: #999;
}

.order-info-value {
  color: #333;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
}

.order-card-footer {
  padding: 20rpx 28rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-total-label {
  font-size: 24rpx;
  color: #999;
}

.order-total-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.order-action-btn {
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  border: 1rpx solid #1a5f9e;
  color: #1a5f9e;
  background: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 128rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}
