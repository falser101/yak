page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.challenge-header {
  background: linear-gradient(135deg, #07c160, #10b981);
  color: white;
  padding: 40rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 10rpx;
  display: block;
}

.challenge-card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.challenge-icon {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.challenge-info {
  flex: 1;
}

.challenge-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.challenge-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}

.progress-bar {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  margin-top: 15rpx;
  overflow: hidden;
}

.progress {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #10b981);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
  display: block;
}

.challenge-badge {
  font-size: 50rpx;
  opacity: 0.3;
}

.challenge-badge.completed {
  opacity: 1;
}

.section {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
}

.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.badge-item {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.badge-icon {
  font-size: 80rpx;
  opacity: 0.3;
}

.badge-icon.owned {
  opacity: 1;
}

.badge-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}
