page {
  background-color: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 分类滚动 */
.cat-scroll {
  white-space: nowrap;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.cat-tabs {
  display: inline-flex;
  padding: 0 12rpx;
}

.cat-tab {
  display: inline-block;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  white-space: nowrap;
}

.cat-tab.active {
  color: #1a5f9e;
  font-weight: 600;
}

.cat-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #1a5f9e;
  border-radius: 3rpx;
}

/* 车辆列表 */
.bike-list {
  padding: 24rpx 32rpx;
}

.bike-list-item {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.bike-thumb {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bike-emoji {
  font-size: 80rpx;
}

.bike-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.bike-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.bike-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.bike-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bike-price {
  font-size: 32rpx;
  color: #ff6b00;
  font-weight: 700;
}

.bike-price .unit {
  font-size: 22rpx;
  font-weight: normal;
  color: #999;
}

.bike-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 240rpx 0;
}

.empty-icon {
  font-size: 200rpx;
  margin-bottom: 60rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
