<view class="container">
  <!-- 车型分类 -->
  <view class="cat-scroll">
    <view class="cat-tabs">
      <view
        class="cat-tab {{currentType === item.key ? 'active' : ''}}"
        wx:for="{{rentalTypes}}"
        wx:key="key"
        bindtap="onTypeChange"
        data-type="{{item.key}}"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- 租车列表 -->
  <view class="bike-list">
    <view class="bike-list-item" wx:for="{{rentalBikes}}" wx:key="id" bindtap="goBikeDetail" data-id="{{item.id}}">
      <view class="bike-thumb" style="background: linear-gradient(135deg, {{item.bikeColor || '#1a5f9e'}}22, {{item.bikeColor || '#1a5f9e'}}11);">
        <text class="bike-emoji">{{item.tag === '热门' ? '🔥' : item.tag === '推荐' ? '⭐' : item.tag === '新品' ? '🆕' : '🚴'}}</text>
      </view>
      <view class="bike-info">
        <view class="bike-title">{{item.name}}</view>
        <view class="bike-desc">{{item.brandName}} · {{item.bikeType}}</view>
        <view class="bike-bottom">
          <view class="bike-price">¥{{item.priceDay}}<text class="unit">/天</text></view>
          <text class="bike-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{rentalBikes.length === 0 && !loading}}">
      <text class="empty-icon">🚴</text>
      <text class="empty-text">暂无可租车辆</text>
    </view>
  </view>
</view>
