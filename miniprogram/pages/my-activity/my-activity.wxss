page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 50rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.activity-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.activity-card {
  width: calc((100% - 20rpx) / 2);
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
}

.activity-cover {
  width: 100%;
  height: 200rpx;
  background: #eee;
}

.activity-info {
  padding: 16rpx;
}

.activity-title {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badges {
  display: flex;
  gap: 8rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.badge {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* 报名状态 badge */
.badge-signup-1 {
  background: #e8f5e9;
  color: #07c160;
}

.badge-signup-2 {
  background: #f5f5f5;
  color: #999;
}

.badge-signup-3 {
  background: #e3f2fd;
  color: #2196f3;
}

/* 活动状态 badge */
.badge-activity-0 {
  background: #e8f5e9;
  color: #07c160;
}

.badge-activity-1 {
  background: #fff3e0;
  color: #ff9800;
}

.badge-activity-2 {
  background: #fce4ec;
  color: #e91e63;
}

.activity-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 10rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.activity-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 600;
}
