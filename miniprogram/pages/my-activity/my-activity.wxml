<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:elif="{{signups.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无报名活动</text>
    <text class="empty-hint">快去参加感兴趣的活动吧</text>
  </view>

  <!-- 活动列表 -->
  <view class="activity-list" wx:else>
    <view class="activity-card" wx:for="{{signups}}" wx:key="activityId" bindtap="goDetail" data-id="{{item.activityId}}">
      <image class="activity-cover" src="{{item.cover || '/images/placeholder.png'}}" mode="aspectFill" />
      <view class="activity-info">
        <text class="activity-title">{{item.title}}</text>
        <view class="status-badges">
          <text class="badge badge-signup-{{item.signupStatus}}">{{item.signupStatusText}}</text>
          <text class="badge badge-activity-{{item.activityStatus}}">{{item.activityStatusText}}</text>
        </view>
        <view class="activity-meta">
          <text class="meta-text">📅 {{item.dateStr}}</text>
          <text class="meta-text">📍 {{item.location}}</text>
        </view>
        <view class="activity-footer">
          <text class="activity-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
