page {
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.container {
  padding: 20rpx;
}

.activity-header {
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.header-cover {
  width: 100%;
  height: 400rpx;
  background: #eee;
}

.header-info {
  padding: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.meta-row .label {
  width: 120rpx;
  color: #666;
}

.meta-row .value {
  color: #333;
}

.meta-row.deadline {
  background: #fff3e0;
  padding: 10rpx;
  border-radius: 6rpx;
  margin-top: 10rpx;
}

.meta-row.deadline .value {
  color: #ff9800;
  font-weight: 500;
}

/* 报名用户列表 */
.signups-list {
  margin-top: 20rpx;
}

.signup-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.signup-item:last-child {
  border-bottom: none;
}

.signup-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-right: 20rpx;
}

.signup-avatar[imageerror] {
  background: #e0e0e0;
}

.signup-info {
  display: flex;
  flex-direction: column;
}

.signup-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.signup-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.section {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
}

.content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
  white-space: pre-wrap;
}

.leader-info {
  display: flex;
  align-items: center;
}

.leader-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
  margin-right: 20rpx;
}

.leader-detail {
  display: flex;
  flex-direction: column;
}

.leader-name {
  font-size: 32rpx;
  font-weight: 600;
}

.leader-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: white;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  border-top: 1rpx solid #eee;
}

.contact-btn {
  padding: 20rpx 40rpx;
  border: 2rpx solid #07c160;
  color: #07c160;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.signup-btn {
  flex: 1;
  background: #07c160;
  color: white;
  border-radius: 8rpx;
}

.signup-btn[disabled] {
  background: #ccc;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-width: 600rpx;
  background: white;
  border-radius: 16rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-item .input,
.form-item .textarea {
  width: 100%;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-item .textarea {
  height: 150rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #eee;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: #07c160;
  color: white;
}

.btn-confirm[disabled] {
  background: #ccc;
}

/* 免责声明弹窗 */
.disclaimer-modal {
  max-width: 680rpx;
  max-height: 85vh;
}

.disclaimer-body {
  display: flex;
  flex-direction: column;
  max-height: calc(85vh - 200rpx);
}

.disclaimer-scroll {
  flex: 1;
  max-height: 55vh;
  padding: 20rpx 30rpx;
}

.disclaimer-content {
  display: flex;
  flex-direction: column;
}

.disclaimer-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-top: 20rpx;
  margin-bottom: 10rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.disclaimer-agree {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  background: #fafafa;
}

.agree-label {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.agree-label checkbox {
  margin-right: 10rpx;
}
